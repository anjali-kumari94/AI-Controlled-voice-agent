# ── Groq API (for Whisper STT) ──────────────────────────────────────────────
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Ollama settings ──────────────────────────────────────────────────────────
# Make sure Ollama is running: `ollama serve`
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3

# ── App settings ─────────────────────────────────────────────────────────────
OUTPUT_DIR=output
